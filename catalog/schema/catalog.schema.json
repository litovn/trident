{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TRIDENT catalog v0.3",
  "description": "Authoritative contract for catalog techniques and packages. Enforced at load time by ranker.Catalog.load (pure-Python subset validator) and usable in CI with any JSON Schema validator.",
  "$defs": {
    "technique": {
      "type": "object",
      "required": ["id", "name", "layer", "phase", "owasp_id", "atlas_tactic", "atlas_technique", "surface", "needs_capabilities", "scorer", "objectives", "severity_base"],
      "properties": {
        "id": { "type": "string", "pattern": "^TRD-(PRM|APP|MOD)-[A-Z0-9]+$" },
        "version": { "$comment": "semver-ish; string or number tolerated (YAML may parse 0.1 as float)" },
        "name": { "type": "string" },
        "desc": { "type": "string" },
        "layer": { "type": "string", "enum": ["prompt", "application", "model"] },
        "phase": { "type": "string", "enum": ["recon", "exploit", "both"] },
        "priority": { "type": "integer" },
        "owasp_id": { "type": "string", "enum": ["LLM01","LLM02","LLM03","LLM04","LLM05","LLM06","LLM07","LLM08","LLM09","LLM10","N/A"] },
        "owasp_name": { "type": "string" },
        "owasp_secondary": { "type": "string", "enum": ["LLM01","LLM02","LLM03","LLM04","LLM05","LLM06","LLM07","LLM08","LLM09","LLM10","N/A"] },
        "atlas_tactic": { "type": "string" },
        "atlas_technique": { "type": "string" },
        "surface": { "type": "string", "enum": ["chat", "retrieval_ingest", "search", "tool"] },
        "needs_capabilities": {
          "type": "array",
          "items": { "type": "string", "enum": ["has_chat","has_retrieval","has_tools","is_agentic","multi_turn","exposes_system_prompt","auth","streaming"] }
        },
        "interaction": { "type": "string", "enum": ["single_turn", "multi_turn"] },
        "intensity": { "type": "string", "enum": ["easy", "moderate", "difficult"] },
        "converters": {
          "type": "array",
          "items": { "type": "string", "enum": ["Baseline","Base64","Flip","Leetspeak","Morse","ROT13","UnicodeConfusable","Url","Diacritic","StringJoin","SuffixAppend","Tense","IndirectAttack","Jailbreak","Crescendo","Multiturn"] }
        },
        "converters_alt": {
          "type": "array",
          "items": { "type": "string", "enum": ["Baseline","Base64","Flip","Leetspeak","Morse","ROT13","UnicodeConfusable","Url","Diacritic","StringJoin","SuffixAppend","Tense","IndirectAttack","Jailbreak","Crescendo","Multiturn"] }
        },
        "scorer": { "type": "string", "enum": ["exfil_canary","leak_detector","output_markup","categorical_match","refusal_judge","judged_objective","cumulative_metric"] },
        "objectives": { "type": "array", "items": { "type": "string" } },
        "success_criterion": { "type": "string", "$comment": "benign, observable success test fed to the LLM judge (decoupled from the attack objective)" },
        "severity_base": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
        "severity_track": { "type": "string", "enum": ["security", "content"] },
        "controls": { "type": "array", "items": { "type": "string" } },
        "aliases": { "type": "array" },
        "intent_examples": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["deferred-mvp"] },
        "scope": { "type": "string", "enum": ["per_attempt", "cumulative"] }
      }
    },
    "package": {
      "type": "object",
      "required": ["id", "name", "techniques"],
      "properties": {
        "id": { "type": "string", "pattern": "^PKG-[A-Z0-9]+$" },
        "name": { "type": "string" },
        "axis": { "type": "string", "enum": ["profile", "layer", "focus"] },
        "aliases": { "type": "array" },
        "intent_examples": { "type": "array", "items": { "type": "string" } },
        "techniques": { "type": "array", "items": { "type": "string", "pattern": "^TRD-(PRM|APP|MOD)-[A-Z0-9]+$" } },
        "limits": {
          "type": "object",
          "properties": {
            "max_intensity": { "type": "string", "enum": ["easy", "moderate", "difficult"] },
            "query_budget": { "type": "integer" }
          }
        },
        "modes": { "type": "array", "items": { "type": "string", "enum": ["recon", "attack"] } }
      }
    }
  }
}
