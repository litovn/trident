
# ═══════════════════════════════════════════════════════════════════════════
# TRIDENT — .env.example
# Copy to .env and fill values.
# ═══════════════════════════════════════════════════════════════════════════
#
# Both the Copilot SDK Coordinator and the Phase-1 ranker route every model
# call through **Microsoft Foundry** via DefaultAzureCredential. All costs
# bill against **Foundry credit** — TRIDENT never consumes GitHub Copilot
# tokens. `FOUNDRY_ENDPOINT` is REQUIRED.
# ═══════════════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════════════
# 1) Microsoft Foundry — model endpoint shared by Coordinator + ranker
# ═══════════════════════════════════════════════════════════════════════════
# Format: https://<account>.cognitiveservices.azure.com/
# Or:     https://<account>.services.ai.azure.com/
FOUNDRY_ENDPOINT=
FOUNDRY_MODEL_DEPLOYMENT=gpt-4o-mini
FOUNDRY_PROJECT_NAME=trident

# AUTH (pick ONE — DefaultAzureCredential is preferred everywhere):
#  - Preferred (cloud + local dev): leave FOUNDRY_API_KEY blank and run
#    `az login` (Managed Identity in production, AzureCLICredential locally).
#  - BYOK shortcut: paste a Foundry key here. In production this should come
#    from Key Vault via Managed Identity, never from .env.
FOUNDRY_API_KEY=
FOUNDRY_API_VERSION=2024-10-21

# Copilot SDK wire protocol against the Azure deployment.
#   chat_completions  -> /chat/completions  (gpt-4o, gpt-4o-mini, gpt-4.1, ...)  [default]
#   responses         -> /responses         (Responses API, 2025+)
#   completions       -> /completions       (legacy text-davinci-style, deprecated)
FOUNDRY_WIRE_API=chat_completions


# ═══════════════════════════════════════════════════════════════════════════
# 2) Ranker overrides — only set if you want DIFFERENT deployments for
#    the Phase-1 NL→scope ranker than for the Coordinator agent.
#    When empty, the ranker reuses FOUNDRY_MODEL_DEPLOYMENT for chat and
#    `text-embedding-3-large` for the embedder. Both must exist in the
#    same Foundry project as FOUNDRY_ENDPOINT.
# ═══════════════════════════════════════════════════════════════════════════
FOUNDRY_EMBED_DEPLOYMENT=text-embedding-3-large
FOUNDRY_CHAT_DEPLOYMENT=


# ═══════════════════════════════════════════════════════════════════════════
# 3) Target endpoints — Rules of Engagement (ADR-008)
# ═══════════════════════════════════════════════════════════════════════════
# Only `memory://echo` and 127.0.0.1 by default (see manifests/sample*.yaml
# `host_allowlist`). Add real target hosts to the manifest, not here.
# This block is just for adapter convenience.
AIGOAT_BASE_URL=http://127.0.0.1:8000
AIGOAT_API_KEY=
AIGOAT_PASSWORD='password123'


# ═══════════════════════════════════════════════════════════════════════════
# 4) Observability — Application Insights (optional)
# ═══════════════════════════════════════════════════════════════════════════
# Provisioned by IaC alongside the Foundry project. Used by the Coordinator +
# vertical sessions for structured trace export beyond the local JSONL.
APPLICATIONINSIGHTS_CONNECTION_STRING=
OTEL_SERVICE_NAME=trident
